# Base URL của backend FastAPI
# Development:
VITE_API_BASE_URL=http://127.0.0.1:8000

# Production: dùng URL HTTPS của backend đã deploy, ví dụ:
# VITE_API_BASE_URL=https://api.your-domain.com

# Google OAuth client ID (optional, dùng cho /api/auth/google)
# Lấy tại: https://console.cloud.google.com/apis/credentials
# KHÔNG commit value thật vào .env.example, chỉ để placeholder
VITE_GOOGLE_CLIENT_ID=
