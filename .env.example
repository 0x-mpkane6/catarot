DATA_DIR=./data
FAISS_INDEX_PATH=./models/vision/faiss.index
FAISS_META_PATH=./models/vision/faiss_meta.json
VISION_STRICT_OPENCLIP=true
VISION_DEMO_MODE=false
RAG_INDEX_PATH=./models/rag/index.faiss
RAG_META_PATH=./models/rag/meta.pkl
OPENAI_API_KEY=
GRADIO_SHARE=false
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b-instruct
OLLAMA_TIMEOUT_SECONDS=120
ASR_MODEL_FASTER=large-v3
ASR_MODEL_TRANSFORMERS=openai/whisper-small
ASR_LANGUAGE_MODE=auto_vi_en
ASR_CANDIDATE_LANGS=vi,en
ASR_BEAM_SIZE=5
ASR_BEST_OF=5
ASR_VAD_FILTER=true
API_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
API_UPLOAD_DIR=tmp_uploads
