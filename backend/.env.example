# =============================================================================
# Tarot backend — mẫu cấu hình môi trường
# Cách dùng: copy file này thành `backend/.env` rồi điền giá trị.
#   - Chạy local: app tự đọc backend/.env qua load_dotenv() trong utils/config.py.
#   - Docker: docker-compose nạp qua `env_file: ./backend/.env` VÀ ghi đè một số
#             biến (API_ALLOWED_ORIGINS, DATABASE_URL, OLLAMA_BASE_URL, WEB_CONCURRENCY).
# Quy ước bật/tắt (bool): 1 / true / yes / y / on = bật; còn lại = tắt.
# KHÔNG commit file .env thật — nó đã nằm trong .gitignore. Key là bí mật.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM — thứ tự ưu tiên: Gemini -> OpenAI -> Ollama -> fallback tất định
# Cần ÍT NHẤT một nguồn để có bản đọc "thật". Không cấu hình nguồn nào thì app
# vẫn chạy nhưng dùng fallback tất định (tiếng Việt, ngắn, theo template).
# -----------------------------------------------------------------------------
# Google Gemini (free tier) — tier ưu tiên. Lấy key: https://aistudio.google.com/apikey
# Để TRỐNG = bỏ qua Gemini.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.6                # 0.0–1.0, cao hơn = sáng tạo/ngẫu nhiên hơn
GEMINI_TIMEOUT_SECONDS=60

# OpenAI — tier 2 (tùy chọn). Để TRỐNG = bỏ qua.
OPENAI_API_KEY=

# Ollama cục bộ — tier 3. true để bật (cần cài Ollama + tải model trước).
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://127.0.0.1:11434   # Docker: đặt http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:3b-instruct
OLLAMA_TIMEOUT_SECONDS=120
SLOW_GENERATION_WARNING_SECONDS=45       # cảnh báo nếu sinh nội dung lâu hơn ngưỡng (giây)

# -----------------------------------------------------------------------------
# Bảo mật / JWT  (QUAN TRỌNG)
# -----------------------------------------------------------------------------
# APP_ENV: để TRỐNG = dev (chỉ in cảnh báo). Đặt =production => bật kiểm tra
# bảo mật NGHIÊM NGẶT (xem JWT_SECRET_KEY bên dưới). PRODUCTION=true cũng được
# hiểu là môi trường production.
APP_ENV=
#
# JWT_SECRET_KEY: khóa BÍ MẬT để ký token đăng nhập — KHÔNG phải "chế độ".
#   Ràng buộc khi APP_ENV=production: nếu để TRỐNG, hoặc thuộc danh sách yếu
#   (change_me, change_me_in_production, change_me_in_production_min_32_chars,
#   secret, changeme), hoặc DÀI < 32 ký tự  =>  app KHÔNG khởi động (RuntimeError).
#   Ở dev: để nguyên placeholder vẫn chạy (chỉ in cảnh báo).
#   Sinh khóa mạnh: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change_me_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=120                 # hạn token đăng nhập (phút), tối thiểu 5
RESET_TOKEN_TTL_MIN=30                 # hạn token đặt lại mật khẩu (phút)
# EXPOSE_RESET_TOKEN_IN_RESPONSE=false # CHỈ dev/test: trả token reset trong API. ĐỪNG bật ở production.

# Google OAuth (đăng nhập bằng Google) — tùy chọn. Để TRỐNG = tắt.
# Phải khớp VITE_GOOGLE_CLIENT_ID ở frontend.
GOOGLE_CLIENT_ID=

# -----------------------------------------------------------------------------
# API / CORS / Rate limit
# -----------------------------------------------------------------------------
# Danh sách origin được phép gọi API (phân tách bằng dấu phẩy).
# LƯU Ý: docker-compose GHI ĐÈ biến này để chấp nhận frontend trong container.
API_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
API_UPLOAD_DIR=tmp_uploads

RATE_LIMIT_ENABLED=true
ASK_RATE_LIMIT_MAX=20                  # số request tối đa cho /api/ask* mỗi cửa sổ
ASK_RATE_LIMIT_WINDOW=60               # độ dài cửa sổ rate limit (giây)

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DB_ENABLED=true
DATABASE_URL=sqlite:///./data/app.db   # Docker ghi đè sang sqlite:///./data/app.db (volume)
DB_ECHO=false                          # true = log mọi câu SQL (ồn, chỉ để debug)

# -----------------------------------------------------------------------------
# Vision / RAG — đường dẫn index FAISS
# -----------------------------------------------------------------------------
DATA_DIR=./data
FAISS_INDEX_PATH=./models/vision/faiss.index
FAISS_META_PATH=./models/vision/faiss_meta.json
VISION_STRICT_OPENCLIP=true            # true = bắt buộc OpenCLIP thật (không cho rơi về demo)
VISION_DEMO_MODE=false                 # true = embedder giả lập (test nhanh, không cần model)
RAG_INDEX_PATH=./models/rag/index.faiss
RAG_META_PATH=./models/rag/meta.pkl

# -----------------------------------------------------------------------------
# ASR — nhận diện giọng nói
# -----------------------------------------------------------------------------
ASR_MODEL_FASTER=large-v3
ASR_MODEL_TRANSFORMERS=openai/whisper-small
ASR_LANGUAGE_MODE=auto_vi_en           # tự nhận diện Việt/Anh
ASR_CANDIDATE_LANGS=vi,en
ASR_BEAM_SIZE=5
ASR_BEST_OF=5
ASR_VAD_FILTER=true
# ASR_TEMPERATURE=0.0
# ASR_INITIAL_PROMPT=

# -----------------------------------------------------------------------------
# Email SMTP — dùng cho báo cáo Oracle & email nhắc đánh giá
# Để TRỐNG SMTP_HOST hoặc SMTP_FROM => KHÔNG gửi email (báo cáo vẫn lưu trong app).
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# -----------------------------------------------------------------------------
# Lịch chạy nền (scheduler) & khác
# -----------------------------------------------------------------------------
RATING_REMINDER_SCHEDULER_ENABLED=true
ARCHETYPE_SCHEDULER_ENABLED=true
ORACLE_SCHEDULER_ENABLED=true
ORACLE_EMAIL_ENABLED=true              # gửi email oracle (cần cấu hình SMTP ở trên)
TIME_CAPSULE_SCHEDULER_ENABLED=true
APP_TIMEZONE=Asia/Ho_Chi_Minh
GRADIO_SHARE=false
